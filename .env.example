# Copy this to .env and fill in credentials
BASE_URL=http://localhost:3001
PT_EMAIL=your-coach@example.com
PT_PASSWORD=yourpassword
CLIENT_EMAIL=your-client@example.com
CLIENT_PASSWORD=yourpassword

# A SECOND, unrelated coach. Required by tests/rls-audit.spec.js — Probe A logs in as this coach
# (who owns no data at all) and asserts every table hands them back zero rows. Without it, the
# cross-tenant isolation audit cannot run. `node scripts/seed-test-data.js` creates the account.
PT2_EMAIL=your-second-coach@example.com
PT2_PASSWORD=yourpassword
